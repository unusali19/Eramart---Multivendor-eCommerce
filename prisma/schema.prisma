

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


enum UserRole {
  USER
  ADMIN
}

enum ShopRole {
  SELLER
  ADMIN
}

enum AddressType {
  HOME
  OFFICE
  OTHER
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum WithdrawStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  password           String
  phoneNumber        String?
  role               UserRole  @default(USER)

  avatarUrl          String?

  resetPasswordToken String?
  resetPasswordTime  DateTime?

  addresses          Address[]
  orders             Order[]
  reviews            Review[]

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Address {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  country     String
  city        String
  address1    String
  address2    String?
  zipCode     String
  type        AddressType @default(HOME)

  orders      Order[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Shop {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  password           String
  phoneNumber        String?
  description        String?
  address            String
  zipCode            String
  role               ShopRole  @default(SELLER)
  active             Boolean @default(false)

  avatarUrl          String?

  availableBalance   Int       @default(0)

  resetPasswordToken String?
  resetPasswordTime  DateTime?

  products           Product[]
  events             Event[]
  coupons            CouponCode[]
  withdrawals        Withdraw[]
  transactions       Transaction[]

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Transaction {
  id         String            @id @default(cuid())
  shopId     String
  shop       Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)

  amount     Int
  status     TransactionStatus @default(PENDING)

  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model Category {
  id            String        @id @default(cuid())
  name          String        @unique

  subCategories SubCategory[]
  products      Product[]
  events        Event[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model SubCategory {
  id          String     @id @default(cuid())
  name        String

  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  products    Product[]
  events      Event[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Product {
  id             String        @id @default(cuid())
  name           String
  tags           String?
  description    String?
  color          String

  originalPrice  Int
  discountPrice  Int
  stock          Int          @default(0)
  ratings        Float        @default(0)
  soldOut        Int          @default(0)

  shopId         String
  shop           Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)

  categoryId     String
  category       Category     @relation(fields: [categoryId], references: [id])

  subCategoryId  String?
  subCategory    SubCategory? @relation(fields: [subCategoryId], references: [id])

  images         ProductImage[]
  reviews        Review[]
  orderItems     OrderItem[]
  coupons        CouponCode[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ProductImage {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  publicId   String
  url        String

  createdAt  DateTime @default(now())
}

model Review {
  id         String   @id @default(cuid())

  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  rating     Int
  comment    String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Order {
  id                String        @id @default(cuid())

  userId            String
  user              User          @relation(fields: [userId], references: [id])

  shippingAddressId String
  shippingAddress   Address       @relation(fields: [shippingAddressId], references: [id])

  totalPrice        Int
  status            OrderStatus   @default(PENDING)

  paymentId         String?       @unique
  payment           PaymentInfo?  @relation(fields: [paymentId], references: [id])

  items             OrderItem[]

  paidAt            DateTime?
  deliveredAt       DateTime?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model OrderItem {
  id         String   @id @default(cuid())

  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId  String
  product    Product  @relation(fields: [productId], references: [id])

  quantity   Int
  price      Int

  createdAt  DateTime @default(now())
}

model PaymentInfo {
  id         String        @id @default(cuid())

  order      Order?

  status     PaymentStatus @default(PENDING)
  type       String

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model Event {
  id             String        @id @default(cuid())
  name           String
  description    String?
  status         String
  tags           String?

  startDate      DateTime
  finishDate     DateTime

  originalPrice  Int
  discountPrice  Int
  stock          Int
  soldOut        Int          @default(0)

  shopId         String
  shop           Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)

  categoryId     String
  category       Category     @relation(fields: [categoryId], references: [id])

  subCategoryId  String?
  subCategory    SubCategory? @relation(fields: [subCategoryId], references: [id])

  images         EventImage[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model EventImage {
  id         String   @id @default(cuid())
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  publicId   String
  url        String

  createdAt  DateTime @default(now())
}

model CouponCode {
  id                String    @id @default(cuid())
  name              String
  value             Int
  minAmount         Int?
  maxAmount         Int?

  shopId            String
  shop              Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  selectedProductId String?
  selectedProduct   Product?  @relation(fields: [selectedProductId], references: [id])

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Withdraw {
  id         String         @id @default(cuid())

  shopId     String
  shop       Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)

  amount     Int
  status     WithdrawStatus @default(PENDING)

  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}